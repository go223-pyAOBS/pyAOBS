*.segy
*.sgy
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# Image / media: ignore common junk dirs; allow UI/assets/figures PNGs
*.jpg
*.jpeg
*.pdf
*.grd
*.nc
# Do NOT blanket-ignore *.png
