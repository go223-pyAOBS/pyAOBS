   "source": [
    "# Hydrous mantle melting\n",
    "\n",
    "This notebook reproduces figures from the hydrous mantle melting model of Katz _et al._ (2003).\n",
    "\n",
    "\n",
    "#### References\n",
    "\n",
    "> Katz, R. F., Spiegelman, M., & Langmuir, C. H. (2003). A new parameterization of hydrous mantle melting. _Geochemistry, Geophysics, Geosystems_, _4_(9), 1–19. https://doi.org/10.1029/2002GC000433"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "0af78a37",
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from melt import katz_2003 as mlt\n",
    "\n",
    "%matplotlib inline"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a897719d",
   "metadata": {},
   "source": [
    "Reproduce __Figure 1__"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "39fd145a",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "<matplotlib.legend.Legend at 0x7fae2e284370>"
      ]
     },
     "execution_count": 2,
     "metadata": {},
     "output_type": "execute_result"
    },
    {
     "data": {
      "image/png": "\n",
      "text/plain": [
       "<Figure size 432x288 with 1 Axes>"
      ]
     },
     "metadata": {
      "needs_background": "light"
     },
     "output_type": "display_data"
    }
   ],
   "source": [
    "# create a pressure range\n",
    "P_range = np.linspace(0, 8, 1000)\n",
    "\n",
    "# plot\n",
    "fig = plt.figure()\n",
    "ax1 = fig.add_subplot(111, xlim=[1080,2020], ylim=[0,8], title='Anhydrous psudo-phase diagram')\n",
    "ax1.set_xlabel('Temperature (°C)')\n",
    "ax1.set_ylabel('Pressure (GPa)')\n",
    "\n",
    "ax1.plot(mlt.T_solidus(P_range), P_range, 'k', label='Solidus')\n",
    "ax1.plot(mlt.T_liquidus(P_range), P_range, 'k--', label='Liquidus')\n",
    "ax1.plot(mlt.T_liquidus_lherz(P_range), P_range, 'k:', label='Lherzolite Liquidus')\n",
    "\n",
    "ax1.invert_yaxis()\n",
    "ax1.grid(True, linestyle=':')\n",
    "ax1.legend()"
   ]
  },
